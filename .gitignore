# Drop-in allowlist for an agent home such as ~/.claude or ~/.codex.
# Default: ignore everything, then keep only human-maintained config and
# versioned policy/prompt material.
*
!*/

# Root metadata and policy documents.
!.gitignore
!README.md
!AGENTS.md
!CLAUDE.md
!CLAUDE.local.md
!SDLC.md

# Human-maintained live config.
!config.toml
!settings.json

# Repository templates/examples.
!config.example.toml
!settings.example.json
!*.example

# Versioned prompt, skill, and policy trees.
!docs
!docs/**
!commands
!commands/**
!prompts-commands
!prompts-commands/**
!skills
!skills/**

# Repository setup helpers.
!setup-*.sh

# Generated/local material, including inside allowed trees.
**/.DS_Store
**/Thumbs.db
**/.venv/
**/__pycache__/
**/*.py[cod]
**/.pytest_cache/
**/.ruff_cache/
**/node_modules/
**/.cache/
**/.tmp/
**/tmp/
**/log/
**/logs/
**/*.log
**/*.cache
**/*.tmp
**/*.swp
**/*~

# Agent runtime state, histories, snapshots, caches, and generated memory.
auth.json
credentials.json
history.jsonl
installation_id
models_cache.json
version.json
stats-cache.json
mcp-needs-auth-cache.json
goals*.sqlite*
logs*.sqlite*
memories*.sqlite*
state*.sqlite*
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.db
*.db-shm
*.db-wal
sessions/**
cache/**
debug/**
todos/**
tasks/**
ide/**
plans/**
session-env/**
shell_snapshots/**
shell-snapshots/**
file-history/**
paste-cache/**
memories/**
memory/**
projects/**
rules/**
statsig/**
telemetry/**
plugins/**
backups/**
auth/**
oauth/**

# Secrets and credential-like files.
*.pem
*.key
*.crt
*.p12
*.pfx
*.token
*.env
.env
.env.*

# Profiling artefacts.
default.profraw
*.profraw
